# Trinity N1B0 4x5 Grid Layout
# Render: d2 01_trinity_grid_layout.d2 01_trinity_grid_layout.svg

grid: {
  grid-rows: 5
  grid-columns: 4
  grid-gap: 8

  # Y=4 (top row) — left to right = X=0,1,2,3
